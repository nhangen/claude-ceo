#!/bin/bash
set -euo pipefail

# ceo — CLI for the CEO agent system.
# Usage: ceo <command> [args]

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"

# Load shared config library
# shellcheck source=ceo-config.sh
source "$SCRIPT_DIR/ceo-config.sh"
ceo_load_config || true

# Scheduler abstraction (crontab on linux/wsl; launchd on macOS)
# shellcheck source=ceo-scheduler.sh
source "$SCRIPT_DIR/ceo-scheduler.sh"

# Find repo root by walking up from scripts/ to find .claude-plugin/
INSTALL_DIR="$SCRIPT_DIR"
while [ "$INSTALL_DIR" != "/" ]; do
  [ -d "$INSTALL_DIR/.claude-plugin" ] && break
  INSTALL_DIR="$(dirname "$INSTALL_DIR")"
done
if [ "$INSTALL_DIR" = "/" ]; then
  INSTALL_DIR="$(dirname "$SCRIPT_DIR")"
fi

# Vault may be unset on a fresh host; help/setup/doctor/next must remain reachable.
# Vault-requiring subcommands call ceo_require_vault in the dispatcher below.
VAULT="${CEO_VAULT:-}"
CEO_DIR="${VAULT:+$VAULT/CEO}"
CEO_CRON="$SCRIPT_DIR/ceo-cron.sh"

_registry_schema_error() {
  local rc="$1"
  case "$rc" in
    1) echo "No registry found. Run: ceo playbook scan" ;;
    2) echo "Registry schema_version missing, malformed, or below $CEO_REGISTRY_SCHEMA_VERSION. Run: ceo playbook scan" ;;
    *) echo "Registry validation failed (rc=$rc)" ;;
  esac
}

_require_registry_current() {
  local registry_file="$1"
  local rc=0
  ceo_registry_validate "$registry_file" || rc=$?
  if [ "$rc" != "0" ]; then
    _registry_schema_error "$rc"
    exit 1
  fi
}

cmd_help() {
  cat <<'USAGE'
Usage: ceo <command>

Commands:
  setup       Provision this machine (install deps, configure git/ssh, cron)
  pr-sources  Configure GitHub/GitLab accounts queried for PR/MR counts
  next        Show post-setup instructions (survives terminal clear)
  test        Run a quick smoke test of the CEO system
  doctor      Check system health (deps, vault, cron, auth)
  preflight   Show which triggers would run vs skip (zero API calls)
  chat        Interactive CEO conversation for a playbook (e.g. ceo chat inbox)
  cron        Run a cron trigger autonomously (e.g. ceo cron pr-triage)
  playbook    Manage playbooks (scan, list, info)
  trace       Show claude-mem observations tagged by a playbook run (ceo trace <name>)
  schedule    List/edit per-user playbook schedules (overrides frontmatter)
  creds       Manage CEO credentials (list, check, path)
  help        Show this message

Examples:
  ceo setup                    # First-time machine setup
  ceo setup discord            # Configure Discord notifications
  ceo pr-sources               # Re-run the GitHub/GitLab account selection
  ceo next                     # Redisplay next steps after claude login
  ceo test                     # Smoke test: run morning-brief, check log
  ceo doctor                   # Verify everything is configured correctly
  ceo preflight                # Preview what cron would do right now
  ceo chat inbox               # Interactive conversation to process inbox
  CEO_CHAT_EFFORT=high ceo chat # Override chat effort (default: medium)
  ceo chat morning-scan        # Morning triage conversation
  ceo cron pr-triage           # Autonomous cron trigger (no conversation)
  ceo playbook scan            # Discover playbooks, update registry + crontab
  ceo schedule                 # List effective schedules + collisions
  ceo schedule morning-scan    # Reschedule one playbook (interactive)
USAGE
}

cmd_next() {
  local next_file="$INSTALL_DIR/next-steps.txt"
  if [ -f "$next_file" ]; then
    cat "$next_file"
  else
    echo "No saved next steps found. Run 'ceo setup' first."
    echo ""
    echo "Post-setup checklist:"
    echo "  1. Run: claude login"
    echo "  2. Run: claude plugin add nhangen/claude-ceo"
    echo "  3. Test: cd $VAULT && claude"
    echo "     Then type: /ceo"
    echo "  4. Test cron: ceo test"
    echo "  5. Enable cron: ceo doctor (shows if cron is installed)"
  fi
}

cmd_doctor() {
  local ok=0
  local warn=0
  local fail=0

  echo "=== CEO Doctor ==="
  echo ""

  # platform
  local _platform
  _platform="$(ceo_detect_os)"
  if [ "$_platform" = "unknown" ]; then
    echo "  ! Platform: unknown — setup helpers may not work"
    warn=$((warn + 1))
  else
    echo "  ✓ Platform: $_platform"
    ok=$((ok + 1))
  fi

  # config file
  local _cfg_path
  _cfg_path="$(ceo_config_path)"
  if [ -f "$_cfg_path" ]; then
    echo "  ✓ Config file found ($HOME/.ceo/config)"
    ok=$((ok + 1))
  else
    echo "  ! Config file not found ($HOME/.ceo/config) — run: ceo setup"
    warn=$((warn + 1))
  fi

  # gh
  if command -v gh &>/dev/null; then
    if gh auth status &>/dev/null 2>&1; then
      echo "  ✓ gh CLI authenticated"
      ok=$((ok + 1))
    else
      echo "  ✗ gh CLI installed but not authenticated — run: gh auth login"
      fail=$((fail + 1))
    fi
  else
    echo "  ✗ gh CLI not found — install: https://cli.github.com"
    fail=$((fail + 1))
  fi

  # pr-sources
  local _pr_sources
  _pr_sources="$(ceo_pr_sources_path)"
  if [ -f "$_pr_sources" ]; then
    local _gh_n _gl_n
    _gh_n=$(ceo_pr_sources_github_accounts "$_pr_sources" | grep -c . || true)
    _gl_n=$(ceo_pr_sources_gitlab_usernames "$_pr_sources" | grep -c . || true)
    echo "  ✓ PR sources configured ($_gh_n github account(s), $_gl_n gitlab username(s))"
    ok=$((ok + 1))
  else
    echo "  ! PR sources not configured ($_pr_sources) — run: ceo pr-sources"
    warn=$((warn + 1))
  fi

  # claude
  if command -v claude &>/dev/null; then
    echo "  ✓ Claude Code installed ($(claude --version 2>/dev/null || echo '?'))"
    ok=$((ok + 1))
  else
    echo "  ✗ Claude Code not found — install: https://claude.ai/download"
    fail=$((fail + 1))
  fi

  # yq
  if command -v yq &>/dev/null; then
    echo "  ✓ yq installed"
    ok=$((ok + 1))
  else
    echo "  ✗ yq not found — install: sudo snap install yq (or brew install yq)"
    fail=$((fail + 1))
  fi

  # syncthing
  if command -v syncthing &>/dev/null; then
    echo "  ✓ Syncthing installed"
    ok=$((ok + 1))
  else
    echo "  ! Syncthing not found — see README.md for install instructions"
    warn=$((warn + 1))
  fi

  # vault
  if [ -f "$CEO_DIR/AGENTS.md" ]; then
    echo "  ✓ CEO vault found at $CEO_DIR/"
    ok=$((ok + 1))
  else
    echo "  ✗ CEO vault not found at $CEO_DIR/"
    echo "    Check Syncthing sync or set CEO_VAULT env var"
    fail=$((fail + 1))
  fi

  # ssh key
  if [ -f "$HOME/.ssh/github_ceo" ]; then
    echo "  ✓ SSH key exists at ~/.ssh/github_ceo"
    ok=$((ok + 1))
  else
    echo "  ! SSH key not found — run: ceo setup"
    warn=$((warn + 1))
  fi

  # cron
  local _sched_state
  _sched_state="$(ceo_scheduler_list 2>/dev/null || true)"
  if printf '%s\n' "$_sched_state" | grep -q "ceo-cron.sh"; then
    local count
    count=$(printf '%s\n' "$_sched_state" | grep -c "ceo-cron.sh")
    echo "  ✓ Cron entries installed ($count triggers)"
    ok=$((ok + 1))

    # Launchd-only: compare on-disk plist count to what launchd has actually
    # loaded. Drift (orphan plist on disk, or loaded job whose plist was
    # rm'd) is the failure mode this check exists to catch.
    if [ "$(ceo_scheduler_backend 2>/dev/null)" = "launchd" ]; then
      local loaded
      loaded="$(ceo_scheduler_loaded_count 2>/dev/null || echo unknown)"
      case "$loaded" in
        unknown)
          echo "  ! Launchd state unreadable — could not query launchctl"
          warn=$((warn + 1))
          ;;
        "$count")
          echo "  ✓ Launchd jobs loaded ($loaded matches plist count)"
          ok=$((ok + 1))
          ;;
        *)
          echo "  ✗ Launchd job count drift: $loaded loaded vs $count plist(s) on disk — run: ceo playbook scan"
          fail=$((fail + 1))
          ;;
      esac
    fi
  else
    echo "  ! No ceo-cron entries in crontab — run: ceo setup"
    warn=$((warn + 1))
  fi

  # duplicate cron triggers
  local dup_count
  dup_count=$(printf '%s\n' "$_sched_state" | grep "ceo-cron\.sh" | sed 's/.*ceo-cron\.sh //' | sort | uniq -d | wc -l | xargs || true)
  if [ "${dup_count:-0}" -gt 0 ]; then
    echo "  ✗ Duplicate cron triggers detected — run: ceo playbook scan"
    fail=$((fail + 1))
  else
    echo "  ✓ No duplicate cron triggers"
    ok=$((ok + 1))
  fi

  # plugin
  if claude plugin list 2>/dev/null | grep -q "ceo"; then
    echo "  ✓ CEO plugin installed in Claude Code"
    ok=$((ok + 1))
  else
    echo "  ! CEO plugin not found — run: claude plugin add nhangen/claude-ceo"
    warn=$((warn + 1))
  fi

  # sync conflicts
  local conflicts
  conflicts=$(find "$CEO_DIR" -name "*.sync-conflict-*" -type f 2>/dev/null | wc -l | xargs)
  if [ "$conflicts" -gt 0 ]; then
    echo "  ! $conflicts Syncthing conflict files found"
    warn=$((warn + 1))
  fi

  # bin symlinks for playbooks
  local registry_file="$CEO_DIR/registry.json"
  if [ ! -f "$registry_file" ]; then
    echo "  ⚠ bin-symlink check skipped: registry.json not found (run: ceo playbook scan)"
    warn=$((warn + 1))
  elif ! command -v jq &>/dev/null; then
    echo "  ⚠ bin-symlink check skipped: jq not on PATH"
    warn=$((warn + 1))
  else
    local registry_rc=0
    ceo_registry_validate "$registry_file" || registry_rc=$?
    if [ "$registry_rc" != "0" ]; then
      echo "  ✗ $(_registry_schema_error "$registry_rc")"
      fail=$((fail + 1))
    else
      local missing_bins=0 bin_total=0
      while IFS= read -r row; do
        local p_name p_bin
        p_name=$(echo "$row" | jq -r '.name')
        p_bin=$(echo "$row" | jq -r '.bin // ""')
        [ -z "$p_bin" ] && continue
        bin_total=$((bin_total + 1))
        local link_name="${p_bin%.sh}"
        if [ ! -L "$HOME/.local/bin/$link_name" ]; then
          echo "  ! Missing bin symlink: ~/.local/bin/$link_name (playbook: $p_name) — run: ceo playbook scan"
          missing_bins=$((missing_bins + 1))
          warn=$((warn + 1))
        fi
      done < <(jq -c '.playbooks[] | select(.status=="active")' "$registry_file" 2>/dev/null)
      if [ "$bin_total" -gt 0 ] && [ "$missing_bins" -eq 0 ]; then
        echo "  ✓ Playbook bin symlinks present ($bin_total)"
        ok=$((ok + 1))
      fi
    fi
  fi

  # playbook drift — only meaningful when both trees exist
  local alert_file="$CEO_DIR/alerts/playbook-drift.md"
  if [ ! -d "$CEO_DIR/playbooks" ] || [ ! -d "${CEO_REPO_PLAYBOOK_DIR:-$INSTALL_DIR/docs/playbooks}" ]; then
    echo "  ? Playbook drift check skipped (vault or repo playbooks dir missing)"
    warn=$((warn + 1))
  elif cmd_playbook_diff --quiet >/dev/null 2>&1; then
    echo "  ✓ Playbooks in sync (no vault/repo drift)"
    ok=$((ok + 1))
    [ -f "$alert_file" ] && rm -f "$alert_file"
  else
    echo "  ✗ Playbook drift detected — run: ceo playbook diff"
    fail=$((fail + 1))
    mkdir -p "$(dirname "$alert_file")"
    {
      echo "---"
      echo "status: drift"
      echo "since: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
      echo "last_check: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
      echo "---"
      echo ""
      echo "# Playbook drift"
      echo ""
      echo "Vault and repo playbook trees diverged. Run \`ceo playbook diff\` for details."
    } > "$alert_file"
  fi

  # Completed-but-no-output cross-check — for every active runner:script
  # playbook with a declared `artifact:`, if today's cron-runs.log says it
  # completed, verify the artifact exists. This catches the #88 / #89 shape
  # where the dispatcher records 'completed' but the script produced no
  # visible side-effect.
  if [ ! -f "$registry_file" ]; then
    echo "  ⚠ doctor artifact cross-check skipped: registry.json not found (run: ceo playbook scan)"
    warn=$((warn + 1))
  elif ! command -v jq &>/dev/null; then
    echo "  ⚠ doctor artifact cross-check skipped: jq not on PATH"
    warn=$((warn + 1))
  elif [ ! -f "$CEO_DIR/log/cron-runs.log" ]; then
    echo "  ⚠ doctor artifact cross-check skipped: cron-runs.log not found"
    warn=$((warn + 1))
  else
    # cron-runs.log lines look like: "Wed May 28 06:00:11 EDT 2026: <name> completed"
    # (written by ceo-cron.sh:47 via $(date)). Force LC_TIME=C when building the
    # prefix so a localized writer/reader pair can't false-negative every match
    # (jeu. mai 28 vs Thu May 28). Anchor the playbook-name match with a regex
    # ending in ` completed$` per `~/.claude/rules/anchored-regex-for-identifier-allowlists.md`
    # so `value-tracker` doesn't substring-match `value-tracker-v2 completed`.
    local _date_prefix _year _host _missing=0 _checked=0
    _date_prefix=$(LC_TIME=C date '+%a %b %e')
    _year=$(date '+%Y')
    _host="${CEO_HOSTNAME:-$(hostname -s 2>/dev/null || echo "")}"
    while IFS= read -r row; do
      local p_name p_artifact p_runner p_status
      p_name=$(echo "$row" | jq -r '.name')
      p_artifact=$(echo "$row" | jq -r '.artifact // ""')
      p_runner=$(echo "$row" | jq -r '.runner // ""')
      p_status=$(echo "$row" | jq -r '.status // ""')
      [ "$p_runner" = "script" ] || continue
      [ "$p_status" = "active" ] || continue
      [ -n "$p_artifact" ] || continue
      LC_TIME=C grep -F -- "$_date_prefix" "$CEO_DIR/log/cron-runs.log" 2>/dev/null \
        | grep -F -- "$_year" \
        | awk -v n="$p_name" '$0 ~ ": "n" completed$"' \
        | grep -q . || continue
      _checked=$((_checked + 1))
      if [ -z "$_host" ] && [[ "$p_artifact" == *"{HOST}"* ]]; then
        echo "  ⚠ '$p_name' artifact template uses {HOST} but hostname -s returned empty — set CEO_HOSTNAME"
        warn=$((warn + 1))
        continue
      fi
      local _rel _abs
      if ! _rel=$(ceo_artifact_expand "$p_artifact" "$_host"); then
        echo "  ✗ Playbook '$p_name' has malformed artifact template '$p_artifact' (unknown token)"
        fail=$((fail + 1))
        continue
      fi
      _abs="$CEO_DIR/${_rel#CEO/}"
      if [ ! -s "$_abs" ]; then
        echo "  ✗ '$p_name' logged 'completed' today but artifact missing or empty: $_abs"
        fail=$((fail + 1))
        _missing=$((_missing + 1))
      fi
    done < <(jq -c '.playbooks[]' "$registry_file" 2>/dev/null)
    if [ "$_checked" -gt 0 ] && [ "$_missing" -eq 0 ]; then
      echo "  ✓ Playbook artifacts present for today's completed runs ($_checked checked)"
      ok=$((ok + 1))
    fi
  fi

  # Drafts surfaced as info — not failures. Promotes via `status: active` flip.
  # Per ~/.claude/rules/safety-invariant-scope.md, surface missing preconditions
  # explicitly rather than silently hiding the check — drafts are exactly the
  # incident shape this PR exists to prevent.
  if [ ! -f "$registry_file" ]; then
    echo "  ⚠ Drafts check skipped: registry.json not found (run: ceo playbook scan)"
    warn=$((warn + 1))
  elif ! command -v jq &>/dev/null; then
    echo "  ⚠ Drafts check skipped: jq not on PATH"
    warn=$((warn + 1))
  else
    local drafts
    drafts=$(jq -r '.playbooks[] | select(.status == "draft") | .name' "$registry_file" 2>/dev/null)
    if [ -n "$drafts" ]; then
      echo ""
      echo "  Drafts (not installed in cron; runnable on-demand):"
      while IFS= read -r d; do
        [ -z "$d" ] && continue
        echo "    - $d  (flip frontmatter to 'status: active' then re-run 'ceo playbook scan' to install)"
      done <<< "$drafts"
    fi
  fi

  # ceo-schedulerd liveness — host-local heartbeat at ~/.ceo/schedulerd/heartbeat.json
  # (never the synced vault). Threshold mirrors HEARTBEAT_STALE_MS in
  # lib/scheduler/src/runtime.ts (600s); keep the two in sync.
  local _hb_file="${HOME:?HOME must be set for the schedulerd heartbeat check}/.ceo/schedulerd/heartbeat.json"
  local _hb_stale_s=600
  if [ ! -f "$_hb_file" ]; then
    echo "  ? ceo-schedulerd not running on this host (no heartbeat) — optional Phase-1.5 daemon"
  elif ! command -v jq &>/dev/null; then
    echo "  ⚠ schedulerd heartbeat check skipped: jq not on PATH"
    warn=$((warn + 1))
  else
    local _hb_ts
    _hb_ts=$(jq -r '.ts // empty' "$_hb_file" 2>/dev/null)
    if [ -z "$_hb_ts" ]; then
      echo "  ✗ ceo-schedulerd heartbeat malformed (no ts) — check the daemon"
      fail=$((fail + 1))
    else
      local _hb_age_s=$(( $(date +%s) - _hb_ts / 1000 ))
      if [ "$_hb_age_s" -gt "$_hb_stale_s" ]; then
        echo "  ✗ ceo-schedulerd heartbeat stale (${_hb_age_s}s old, > ${_hb_stale_s}s) — daemon may be down"
        fail=$((fail + 1))
      else
        echo "  ✓ ceo-schedulerd alive (heartbeat ${_hb_age_s}s ago)"
        ok=$((ok + 1))
      fi
    fi
  fi

  echo ""
  echo "Result: $ok ok, $warn warnings, $fail failures"
  [ "$fail" -gt 0 ] && return 1
  return 0
}

cmd_test() {
  echo "=== CEO Smoke Test ==="
  echo ""

  # Pre-flight
  cmd_doctor || true
  echo ""

  if [ ! -f "$CEO_CRON" ]; then
    echo "ERROR: ceo-cron.sh not found at $CEO_CRON"
    exit 1
  fi

  echo "Running morning-brief trigger (bypassing cooldown)..."
  echo "  This calls claude --print which may take 1-2 minutes."
  echo ""
  CEO_FORCE=1 CEO_VERBOSE=1 "$CEO_CRON" morning-brief
  local exit_code=$?

  echo ""
  if [ $exit_code -eq 0 ]; then
    local today
    today=$(date +%Y-%m-%d)
    local log_file="$CEO_DIR/log/$today.md"
    if [ -f "$log_file" ]; then
      echo "Log written to: $log_file"
      echo ""
      tail -20 "$log_file"
    else
      echo "WARNING: Trigger succeeded but no log file found at $log_file"
    fi
  else
    echo "FAILED (exit code: $exit_code)"
    echo "Check: $CEO_DIR/log/cron-skips.log"
    echo "Check: $CEO_DIR/log/cron-raw.log"
  fi
}

cmd_preflight() {
  echo "=== CEO Preflight Check ==="
  echo ""

  # Gather data (same as cron does)
  source "$SCRIPT_DIR/ceo-gather.sh"

  # Settings
  local settings_file="$CEO_DIR/settings.json"
  local branch_prefix="ceo/"
  if command -v jq &>/dev/null && [ -f "$settings_file" ]; then
    branch_prefix=$(jq -r '.branch_prefix // "ceo/"' "$settings_file" 2>/dev/null || echo "ceo/")
  fi
  local log_file
  log_file="$CEO_DIR/log/$(date +%Y-%m-%d).md"

  # Define preflights inline (can't source from ceo-cron.sh mid-script)
  preflight_none() { return 0; }
  preflight_has_unchecked_inbox() {
    ceo_inbox_has_unchecked
  }
  preflight_has_prs_to_review() {
    [ "${PR_REVIEW_COUNT:-0}" -gt 0 ]
  }
  preflight_has_pending_items() {
    [ "${PENDING_COUNT:-0}" -gt 0 ]
  }
  preflight_has_log_entries_after_4pm() {
    local hour
    hour=$(date +%H)
    [ "$hour" -ge 16 ] && [ -f "$log_file" ] && grep -q "^## " "$log_file"
  }
  preflight_has_ceo_branches() {
    local repos_file="$CEO_DIR/repos.md"
    [ -f "$repos_file" ] || return 1
    while IFS= read -r repo_path; do
      repo_path=$(echo "$repo_path" | xargs)
      [ -d "$repo_path" ] && git -C "$repo_path" branch --list "${branch_prefix}*" 2>/dev/null | grep -q . && return 0
    done < <(grep "^|" "$repos_file" | grep -v "^| Repo\|^|---" | awk -F'|' '{print $3}')
    return 1
  }

  local registry_file="$CEO_DIR/registry.json"
  _require_registry_current "$registry_file"

  local would_run=0
  local would_skip=0

  echo "  Data: PRs for review=$PR_REVIEW_COUNT | PRs authored=$PR_AUTHORED_COUNT"
  echo "  Data: Pending=$PENDING_COUNT | Approved=$APPROVED_COUNT"
  echo ""

  while IFS='|' read -r name model preflight status; do
    [ "$status" != "active" ] && continue

    local fn="preflight_${preflight:-none}"
    local result="?"
    if type "$fn" &>/dev/null; then
      if "$fn" 2>/dev/null; then
        result="RUN"
        would_run=$((would_run + 1))
      else
        result="SKIP"
        would_skip=$((would_skip + 1))
      fi
    else
      result="RUN (unknown preflight)"
      would_run=$((would_run + 1))
    fi

    printf "  %-18s %-8s %-30s → %s\n" "$name" "$model" "$preflight" "$result"
  done < <(jq -r '.playbooks[] | "\(.name)|\(.model)|\(.preflight)|\(.status)"' "$registry_file")

  echo ""
  echo "Result: $would_run would run, $would_skip would skip"
  echo "Estimated API calls: $((would_run * 2)) (plan + execute per trigger)"
}

cmd_playbook() {
  local subcmd="${1:-help}"
  shift 2>/dev/null || true
  case "$subcmd" in
    scan) cmd_playbook_scan "$@" ;;
    list) cmd_playbook_list ;;
    info) cmd_playbook_info "$@" ;;
    diff) cmd_playbook_diff "$@" ;;
    help|--help|-h)
      echo "Usage: ceo playbook <scan|list|info|diff>"
      echo ""
      echo "  scan [--dry-run]   Discover playbooks, update registry + crontab"
      echo "                     (--dry-run prints would-be cron block, no writes)"
      echo "  list               Show all registered playbooks"
      echo "  info <name>        Show details for one playbook"
      echo "  diff [--quiet]     Detect drift between vault and repo playbooks"
      ;;
    *)
      echo "Unknown playbook command: $subcmd"
      echo "Run: ceo playbook help"
      exit 1
      ;;
  esac
}

cmd_playbook_diff() {
  : "${CEO_VAULT:?CEO_VAULT must be set before ceo playbook diff}"
  local vault_dir="$CEO_DIR/playbooks"
  local repo_dir="${CEO_REPO_PLAYBOOK_DIR:-$INSTALL_DIR/docs/playbooks}"
  local quiet=""
  for arg in "$@"; do
    case "$arg" in
      --quiet) quiet="--quiet" ;;
    esac
  done

  if [ ! -d "$vault_dir" ]; then
    [ "$quiet" != "--quiet" ] && echo "ERROR: Vault playbooks directory not found at $vault_dir" >&2
    return 2
  fi
  if [ ! -d "$repo_dir" ]; then
    [ "$quiet" != "--quiet" ] && echo "ERROR: Repo playbooks directory not found at $repo_dir" >&2
    return 2
  fi

  local drift=0

  # Check vault vs repo
  for f in "$vault_dir"/*.md; do
    [ -f "$f" ] || continue
    local base="${f##*/}"
    if [ ! -f "$repo_dir/$base" ]; then
      [ "$quiet" != "--quiet" ] && echo "Vault only: $base"
      drift=$((drift + 1))
    else
      local cmp_rc=0
      cmp -s "$f" "$repo_dir/$base" || cmp_rc=$?
      if [ "$cmp_rc" -eq 0 ]; then
        :
      elif [ "$cmp_rc" -eq 1 ]; then
        [ "$quiet" != "--quiet" ] && echo "Differs: $base"
        if [ "$quiet" != "--quiet" ]; then
          diff -u "$repo_dir/$base" "$f" || true
        fi
        drift=$((drift + 1))
      else
        echo "ERROR: cmp failed (rc=$cmp_rc) comparing $f vs $repo_dir/$base — treating as drift" >&2
        drift=$((drift + 1))
      fi
    fi
  done

  # Check repo vs vault
  for f in "$repo_dir"/*.md; do
    [ -f "$f" ] || continue
    local base="${f##*/}"
    if [ ! -f "$vault_dir/$base" ]; then
      [ "$quiet" != "--quiet" ] && echo "Repo only: $base"
      drift=$((drift + 1))
    fi
  done

  if [ "$drift" -gt 0 ]; then
    return 1
  else
    [ "$quiet" != "--quiet" ] && echo "No drift detected between $vault_dir and $repo_dir"
    return 0
  fi
}

cmd_playbook_scan() {
  # Extract a scalar field from YAML frontmatter without requiring yq.
  # Handles quoted and unquoted values; returns empty string if absent.
  _fm_scalar() {
    local field="$1" file="$2"
    awk -v f="$field" '
      /^---[[:space:]]*$/ { fence++; next }
      fence >= 2 { exit }
      fence == 1 {
        if (match($0, "^" f ":")) {
          val = substr($0, RSTART + length(f) + 1)
          gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
          gsub(/^["'"'"']|["'"'"']$/, "", val)
          print val; exit
        }
      }
    ' "$file" 2>/dev/null
  }
  # Extract a YAML flow-sequence field and emit as a JSON array, or "null".
  # Handles: [item1, item2] -> ["item1","item2"]. Scalars/absent -> null.
  _fm_array_json() {
    local field="$1" file="$2"
    # Two-pass approach avoids awk function definitions (which confuse bash quoting).
    # Pass 1: look for an inline flow sequence or scalar on the same line as the field.
    local inline
    inline=$(_fm_scalar "$field" "$file")
    if [ -n "$inline" ] && [ "$inline" != "null" ]; then
      if [ "${inline:0:1}" = "[" ] && [ "${inline: -1}" = "]" ]; then
        # Flow sequence — convert to JSON array.
        echo "$inline" | awk '{
          inner = substr($0, 2, length($0)-2)
          n = split(inner, a, /,[[:space:]]*/);
          printf "["
          for (i=1;i<=n;i++) {
            gsub(/^[[:space:]]+|[[:space:]]+$/,"",a[i])
            gsub(/^["'"'"']|["'"'"']$/,"",a[i])
            printf "%s\"%s\"",(i>1?",":""),a[i]
          }
          printf "]\n"
        }' 2>/dev/null
      else
        # Scalar — return raw so caller can warn "must be an array".
        echo "$inline"
      fi
      return
    fi
    # Pass 2: look for a block sequence (field: on its own line, then "  - item" lines).
    awk -v f="$field" '
      /^---[[:space:]]*$/ { fence++; next }
      fence >= 2 { exit }
      fence == 1 && !found && match($0, "^" f ":") {
        val = substr($0, RSTART+length(f)+1); gsub(/^[[:space:]]+/,"",val)
        if (val == "" || val == "null") { found=1 }
      }
      found && /^[[:space:]]+-[[:space:]]/ {
        item=$0; gsub(/^[[:space:]]+-[[:space:]]+/,"",item)
        gsub(/^[[:space:]]+|[[:space:]]+$/,"",item)
        items[++n]=item
      }
      found && n>0 && !/^[[:space:]]+-[[:space:]]/ && !/^---/ && !/^[[:space:]]*$/ && !match($0,"^"f":") { exit }
      END {
        if (n==0) { print "null"; exit }
        printf "["
        for(i=1;i<=n;i++) printf "%s\"%s\"",(i>1?",":""),items[i]
        printf "]\n"
      }
    ' "$file" 2>/dev/null
  }

  local dry_run=0
  for arg in "$@"; do
    case "$arg" in
      --dry-run) dry_run=1 ;;
      *)
        # Reject unknown args rather than fall through to a real scan —
        # `--dryrun` typo must not silently run the destructive path. Per
        # ~/.claude/rules/enum-config-typo-fallback.md.
        echo "ERROR: unknown scan argument: '$arg' (supported: --dry-run)" >&2
        return 1
        ;;
    esac
  done

  ceo_validate_vault || exit 1
  ceo_assert_primary_host || exit 1

  local playbook_dir="$CEO_DIR/playbooks"
  local repo_playbook_dir="${CEO_REPO_PLAYBOOK_DIR:-$INSTALL_DIR/docs/playbooks}"
  local registry_file="$CEO_DIR/registry.json"

  if [ ! -d "$playbook_dir" ]; then
    echo "ERROR: Playbooks directory not found at $playbook_dir"
    exit 1
  fi

  local old_registry='{"playbooks":[]}'
  if [ -f "$registry_file" ]; then
    if ! jq -e 'type == "object"' "$registry_file" >/dev/null 2>&1; then
      echo "ERROR: refusing to overwrite unparseable registry: $registry_file"
      exit 1
    fi
    if jq -e 'has("schema_version")' "$registry_file" >/dev/null 2>&1; then
      local existing_v
      existing_v=$(ceo_registry_version "$registry_file")
      if [ -z "$existing_v" ]; then
        echo "ERROR: refusing to overwrite registry with malformed schema_version."
        echo "Fix or remove $registry_file, then rerun ceo playbook scan."
        exit 1
      fi
      if [ "$existing_v" -gt "$CEO_REGISTRY_SCHEMA_VERSION" ]; then
        echo "ERROR: refusing to downgrade registry (on-disk schema_version=$existing_v, this binary writes $CEO_REGISTRY_SCHEMA_VERSION)."
        echo "Update this host's claude-ceo binary first."
        exit 1
      fi
    fi
    old_registry=$(cat "$registry_file")
  fi

  local new_registry
  new_registry=$(jq -n \
    --argjson v "$CEO_REGISTRY_SCHEMA_VERSION" \
    --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    '{schema_version: $v, generated: $ts, playbooks: []}')
  local found=0
  local skipped=0
  # Tracked separately from `skipped` so a typo'd enum can propagate to
  # cmd_playbook_scan's exit code per ~/.claude/rules/enum-config-typo-fallback.md
  # ("failed dispatch counts toward failure observability").
  local invalid_status=0

  local seen_names_vault=""
  local seen_names_repo=""
  local shadowed=0

  local scan_dirs=( "$playbook_dir" )
  [ -d "$repo_playbook_dir" ] && scan_dirs+=( "$repo_playbook_dir" )

  for d in "${scan_dirs[@]}"; do
    for f in "$d"/*.md; do
      [ -f "$f" ] || continue
    local basename
    basename=$(basename "$f")
    local from_repo=0
    [ "$d" = "$repo_playbook_dir" ] && from_repo=1

    local name description trigger schedule model preflight tier status bin runner script inputs skill out_pattern requires artifact _artifact_residual
    name=$(_fm_scalar name "$f")
    if [ -z "$name" ]; then
      echo "  SKIP  $basename (no name in frontmatter)"
      skipped=$((skipped + 1))
      continue
    fi

    case "$name" in
      *$'\n'*)
        echo "  SKIP  $basename (name contains newline; YAML block scalars not supported)"
        skipped=$((skipped + 1))
        continue
        ;;
    esac

    if grep -qxF "$name" <<< "$seen_names_vault"; then
      if [ "$from_repo" = "1" ]; then
        echo "  SHADOW $basename (vault override of repo playbook '$name')"
        shadowed=$((shadowed + 1))
      else
        echo "  DUP    $basename (duplicate name '$name')"
        skipped=$((skipped + 1))
      fi
      continue
    fi
    if grep -qxF "$name" <<< "$seen_names_repo"; then
      echo "  DUP    $basename (duplicate name '$name')"
      skipped=$((skipped + 1))
      continue
    fi
    if [ "$from_repo" = "1" ]; then
      seen_names_repo="${seen_names_repo}${name}"$'\n'
    else
      seen_names_vault="${seen_names_vault}${name}"$'\n'
    fi

    description=$(_fm_scalar description "$f")
    trigger=$(_fm_scalar trigger "$f")
    schedule=$(_fm_scalar schedule "$f")
    model=$(_fm_scalar model "$f")
    preflight=$(_fm_scalar preflight "$f")
    tier=$(_fm_scalar tier "$f")
    status=$(_fm_scalar status "$f")
    if [ -n "$status" ] && ! ceo_status_valid "$status"; then
      echo "  SKIP  $basename (unknown status: '$status', expected: ${CEO_VALID_STATUSES[*]})" >&2
      skipped=$((skipped + 1))
      invalid_status=$((invalid_status + 1))
      continue
    fi
    bin=$(_fm_scalar bin "$f")
    runner=$(_fm_scalar runner "$f")
    script=$(_fm_scalar script "$f")
    skill=$(_fm_scalar skill "$f")
    out_pattern=$(_fm_scalar out_pattern "$f")
    artifact=$(_fm_scalar artifact "$f")
    # Validate at parse time per enum-config-typo-fallback: an artifact
    # template must be vault-relative ("CEO/...") and reference only the
    # supported tokens {TODAY} and {HOST}. Reject anything else with a warn,
    # treating it as absent — better to skip the doctor cross-check than emit
    # a broken path on every check.
    if [ -n "$artifact" ]; then
      case "$artifact" in
        CEO/*) ;;
        *)
          echo "  WARN  $basename: 'artifact' must be vault-relative (start with 'CEO/'); got: $artifact — dropping" >&2
          artifact=""
          ;;
      esac
    fi
    if [ -n "$artifact" ]; then
      _artifact_residual=$(printf '%s' "$artifact" | sed -e 's/{TODAY}//g' -e 's/{HOST}//g')
      case "$_artifact_residual" in
        *\{*\}*)
          echo "  WARN  $basename: 'artifact' contains unknown token(s) (supported: {TODAY}, {HOST}); got: $artifact — dropping" >&2
          artifact=""
          ;;
      esac
    fi
    requires=$(_fm_array_json requires "$f")
    case "$requires" in
      "null"|"") requires="null" ;;
      \[*\]) ;;
      *)
        echo "  WARN  $basename: 'requires' must be an array (got: $(echo "$requires" | head -c 60)) — defaulting to none" >&2
        requires="null"
        ;;
    esac
    # `inputs` is an optional array of pre-gather keys to inject into the prompt.
    # Absent → all keys (backward-compatible default). [] → none. Non-array →
    # warn and treat as absent (per enum-config-typo-fallback rule). yq emits
    # a JSON array as a "compact" string when shaped right; we capture raw JSON.
    inputs=$(_fm_array_json inputs "$f")
    case "$inputs" in
      "null"|"") inputs="null" ;;
      \[*\])
        # Validate each entry is a known canonical key. Unknown keys produce
        # a warn-and-keep — the dispatcher sees the typoed key and skips it.
        # This matches the enum-config-typo-fallback rule: validate at parse,
        # gate at dispatch, never silently coerce.
        local unknown_keys
        unknown_keys=$(echo "$inputs" | jq -r '
          ["pr_data","pending_count","today_log","yesterday_log","daily_note","briefings_training","active_domains","pending_ask","scan_data","blessings"] as $valid
          | .[]? | select(. as $k | $valid | index($k) | not)
        ' 2>/dev/null | tr '\n' ' ' | sed 's/ $//')
        if [ -n "$unknown_keys" ]; then
          echo "  WARN  $basename: 'inputs' contains unknown key(s): $unknown_keys — ignored at dispatch. Known: pr_data, pending_count, today_log, yesterday_log, daily_note, briefings_training, active_domains, pending_ask, scan_data, blessings" >&2
        fi
        ;;
      *)
        echo "  WARN  $basename: 'inputs' must be an array (got: $(echo "$inputs" | head -c 60)) — defaulting to all" >&2
        inputs="null"
        ;;
    esac

    # `hosts` scopes which machines a playbook runs on. Absent → ["*"] (all
    # hosts). Recorded in the registry but NOT enforced in Phase 1 — the daemon
    # (Phase 1.5) consumes it. Validate shape at parse and default malformed
    # values to ["*"] rather than silently scoping to nowhere or a typo'd host
    # (per enum-config-typo-fallback). An empty array means "runs nowhere",
    # which is a likely mistake — use status:disabled to stop a playbook.
    hosts=$(_fm_array_json hosts "$f")
    case "$hosts" in
      "null"|"") hosts='["*"]' ;;
      \[*\])
        if ! echo "$hosts" | jq -e 'type=="array" and length>0 and all(.[]; type=="string" and test("\\S"))' >/dev/null 2>&1; then
          echo "  WARN  $basename: 'hosts' must be a non-empty array of host names (got: $(echo "$hosts" | head -c 60)) — defaulting to [\"*\"] (all hosts)" >&2
          hosts='["*"]'
        fi
        ;;
      *)
        echo "  WARN  $basename: 'hosts' must be an array (got: $(echo "$hosts" | head -c 60)) — defaulting to [\"*\"] (all hosts)" >&2
        hosts='["*"]'
        ;;
    esac

    local runner_valid=0
    [ -z "$runner" ] && runner_valid=1
    for r in "${CEO_VALID_RUNNERS[@]}"; do
      [ "$runner" = "$r" ] && { runner_valid=1; break; }
    done
    if [ "$runner_valid" -eq 0 ]; then
      echo "  SKIP  $basename (unknown runner: '$runner', expected: ${CEO_VALID_RUNNERS[*]})"
      skipped=$((skipped + 1))
      continue
    fi

    if [ "$runner" = "ollama" ] || [ "$runner" = "ollama-think" ]; then
      local effective_model="$model"
      if [ "$runner" = "ollama" ]; then
        [ -z "$effective_model" ] && effective_model="mistral-small3.2:24b"
      else
        [ -z "$effective_model" ] && effective_model="gpt-oss:20b"
      fi

      if [ -z "${CEO_OLLAMA_SKIP_PROBE:-}" ]; then
        if ! command -v ollama &>/dev/null; then
          echo "  SKIP  $basename (ollama CLI not found)"
          skipped=$((skipped + 1))
          continue
        fi

        ceo_resolve_timeout_bin
        local ollama_models ollama_rc
        if [ -n "$CEO_TIMEOUT_BIN" ]; then
          ollama_models=$("$CEO_TIMEOUT_BIN" 3 ollama list 2>/dev/null | awk 'NR>1 {print $1}')
          ollama_rc=${PIPESTATUS[0]}
        else
          ollama_models=$(ollama list 2>/dev/null | awk 'NR>1 {print $1}')
          ollama_rc=${PIPESTATUS[0]}
        fi
        case "$ollama_rc" in
          0) : ;;
          124) echo "  SKIP  $basename (ollama daemon hung — 'ollama list' timed out)"; skipped=$((skipped + 1)); continue ;;
          *)   echo "  SKIP  $basename (ollama list failed rc=$ollama_rc — daemon down? run 'ollama serve')"; skipped=$((skipped + 1)); continue ;;
        esac
        if ! echo "$ollama_models" | grep -Fxq -- "$effective_model"; then
          echo "  SKIP  $basename (model '$effective_model' not found locally; run 'ollama pull $effective_model')"
          skipped=$((skipped + 1))
          continue
        fi
      fi
    fi

    local entry_file
    if [ "$from_repo" = "1" ]; then
      entry_file="$f"
    else
      entry_file="playbooks/$basename"
    fi

    local entry
    entry=$(jq -n \
      --arg name "$name" \
      --arg description "$description" \
      --arg trigger "$trigger" \
      --arg schedule "$schedule" \
      --arg model "$model" \
      --arg preflight "$preflight" \
      --arg tier "$tier" \
      --arg status "$status" \
      --arg bin "$bin" \
      --arg runner "$runner" \
      --arg script "$script" \
      --arg skill "$skill" \
      --arg out_pattern "$out_pattern" \
      --arg artifact "$artifact" \
      --argjson inputs "$inputs" \
      --argjson requires "$requires" \
      --argjson hosts "$hosts" \
      --arg file "$entry_file" \
      '{name:$name, description:$description, trigger:$trigger, schedule:$schedule, model:$model, preflight:$preflight, tier:$tier, status:$status, bin:$bin, runner:$runner, script:$script, skill:$skill, out_pattern:$out_pattern, artifact:$artifact, inputs:$inputs, requires:$requires, hosts:$hosts, file:$file}')

    new_registry=$(echo "$new_registry" | jq --argjson entry "$entry" '.playbooks += [$entry]')
    found=$((found + 1))
    done
  done

  # Compare old vs new
  local added=0 updated=0 removed=0 unchanged=0
  local old_names new_names
  old_names=$(echo "$old_registry" | jq -r '.playbooks[].name' 2>/dev/null | sort)
  new_names=$(echo "$new_registry" | jq -r '.playbooks[].name' | sort)

  while IFS= read -r n; do
    [ -z "$n" ] && continue
    if ! echo "$old_names" | grep -qx "$n"; then
      echo "  ADD   $n"
      added=$((added + 1))
    else
      local old_hash new_hash
      old_hash=$(echo "$old_registry" | jq -r --arg n "$n" '.playbooks[] | select(.name==$n) | del(.file) | tojson' | md5 2>/dev/null || echo "$old_registry" | jq -r --arg n "$n" '.playbooks[] | select(.name==$n) | del(.file) | tojson' | md5sum 2>/dev/null | awk '{print $1}')
      new_hash=$(echo "$new_registry" | jq -r --arg n "$n" '.playbooks[] | select(.name==$n) | del(.file) | tojson' | md5 2>/dev/null || echo "$new_registry" | jq -r --arg n "$n" '.playbooks[] | select(.name==$n) | del(.file) | tojson' | md5sum 2>/dev/null | awk '{print $1}')
      if [ "$old_hash" = "$new_hash" ]; then
        unchanged=$((unchanged + 1))
      else
        echo "  UPD   $n"
        updated=$((updated + 1))
      fi
    fi
  done <<< "$new_names"

  while IFS= read -r n; do
    [ -z "$n" ] && continue
    if ! echo "$new_names" | grep -qx "$n"; then
      echo "  DEL   $n"
      removed=$((removed + 1))
    fi
  done <<< "$old_names"

  # Apply schedule overrides — registry should reflect effective schedules.
  new_registry=$(_playbook_apply_schedule_overrides "$new_registry")

  if [ "$dry_run" -eq 1 ]; then
    echo ""
    echo "=== DRY-RUN: would-be crontab block (no changes applied) ==="
    _playbook_print_cron_block "$new_registry"
    echo ""
    echo "Registry: $found playbooks ($added added, $updated updated, $removed removed, $unchanged unchanged, $skipped skipped, $shadowed shadowed) — NOT written"
    if [ "$invalid_status" -gt 0 ]; then
      echo "ERROR: $invalid_status playbook(s) skipped due to invalid status — see SKIP lines above" >&2
      return 1
    fi
    return 0
  fi

  # Update crontab FIRST. If collision detection refuses, abort before
  # touching the registry on disk — otherwise a refused scan would persist
  # the conflicting state into registry.json and confuse later `ceo schedule`
  # listings. Propagate the scheduler's rc so callers / cron / CI can see
  # transient failures (rc=1) distinctly from a clean abort.
  local _scan_install_rc=0
  _playbook_update_crontab "$new_registry" || _scan_install_rc=$?
  if [ "$_scan_install_rc" -ne 0 ]; then
    echo "Aborted: registry not updated. See error above and re-run." >&2
    return "$_scan_install_rc"
  fi

  local registry_tmp="$registry_file.tmp"
  echo "$new_registry" | jq '.' > "$registry_tmp"
  mv "$registry_tmp" "$registry_file"

  echo ""
  echo "Registry: $found playbooks ($added added, $updated updated, $removed removed, $unchanged unchanged, $skipped skipped, $shadowed shadowed)"
  echo "Wrote: $registry_file"

  _playbook_sync_bins "$new_registry"

  if [ "$invalid_status" -gt 0 ]; then
    echo "ERROR: $invalid_status playbook(s) skipped due to invalid status — see SKIP lines above" >&2
    return 1
  fi
}

_playbook_sync_bins() {
  : "${HOME:?HOME must be set before _playbook_sync_bins}"
  local registry="$1"
  local bin_dir="$HOME/.local/bin"
  local manifest_dir="$HOME/.ceo"
  local manifest="$manifest_dir/managed-bins"
  mkdir -p "$bin_dir" "$manifest_dir"

  local created=0
  local removed=0
  local declared_names=""

  while IFS= read -r row; do
    local p_name p_bin p_status
    p_name=$(echo "$row" | jq -r '.name')
    p_bin=$(echo "$row" | jq -r '.bin // ""')
    p_status=$(echo "$row" | jq -r '.status')

    [ -z "$p_bin" ] && continue
    [ "$p_status" != "active" ] && continue

    local link_name="${p_bin%.sh}"
    local link_path="$bin_dir/$link_name"
    local target="$SCRIPT_DIR/$p_bin"

    ln -sf "$target" "$link_path"
    echo "  BIN   $link_name -> $target"
    declared_names+="$link_name"$'\n'
    created=$((created + 1))
  done < <(echo "$registry" | jq -c '.playbooks[]')

  # Prune only entries this function created previously. The manifest lists
  # link names from the most recent successful sync; user-installed CLIs
  # (e.g. ~/.local/bin/ceo, ~/.local/bin/count-blessings) are never recorded
  # there and so survive every scan.
  if [ -f "$manifest" ]; then
    while IFS= read -r prev_name; do
      [ -z "$prev_name" ] && continue
      printf '%s' "$declared_names" | grep -Fqx "$prev_name" && continue
      local link="$bin_dir/$prev_name"
      [ -L "$link" ] || continue
      local tgt
      tgt=$(readlink "$link")
      [[ "$tgt" == "$SCRIPT_DIR/"* ]] || continue
      rm -f "$link"
      echo "  UNBIN $prev_name (removed)"
      removed=$((removed + 1))
    done < "$manifest"
  fi

  local manifest_tmp
  manifest_tmp=$(mktemp "$manifest.XXXXXX") || {
    echo "WARN: mktemp failed for manifest" >&2
    return 1
  }
  if ! printf '%s' "$declared_names" > "$manifest_tmp" || ! mv -f "$manifest_tmp" "$manifest"; then
    rm -f "$manifest_tmp"
    echo "WARN: manifest update failed" >&2
    return 1
  fi

  echo "Bins: $created created/updated, $removed removed"
}

# Apply per-user schedule overrides from $CEO_DIR/schedules.json.
# Frontmatter `schedule:` is the default; values in schedules.json win.
# Echoes the merged registry (or the input registry unchanged if no overrides).
# Validation: file must be valid JSON, override key must name a known playbook,
# value must be a 5-field cron expression. Anything else is warned-and-ignored
# per the enum-config-typo-fallback rule — never silently coerced.
_playbook_apply_schedule_overrides() {
  local registry="$1"
  local overrides_file="$CEO_DIR/schedules.json"

  if [ ! -f "$overrides_file" ]; then
    echo "$registry"
    return 0
  fi

  if ! jq empty "$overrides_file" 2>/dev/null; then
    echo "WARNING: $overrides_file is not valid JSON; ignoring all overrides" >&2
    echo "$registry"
    return 0
  fi

  local known_playbooks
  known_playbooks=$(echo "$registry" | jq -r '.playbooks[].name')

  local override_keys
  override_keys=$(jq -r 'keys[]' "$overrides_file")

  while IFS= read -r override_name; do
    [ -z "$override_name" ] && continue

    if ! echo "$known_playbooks" | grep -qFx "$override_name"; then
      echo "WARNING: $overrides_file references unknown playbook '$override_name' — ignored" >&2
      continue
    fi

    local override_schedule
    override_schedule=$(jq -r --arg n "$override_name" '.[$n]' "$overrides_file")
    if [ -z "$override_schedule" ] || [ "$override_schedule" = "null" ]; then
      continue
    fi

    if [ "$(echo "$override_schedule" | awk '{print NF}')" != "5" ]; then
      echo "WARNING: $overrides_file: '$override_name' has invalid cron expression '$override_schedule' (need 5 space-separated fields) — ignored" >&2
      continue
    fi

    registry=$(echo "$registry" | jq --arg n "$override_name" --arg s "$override_schedule" \
      '.playbooks |= map(if .name == $n then .schedule = $s else . end)')
  done <<< "$override_keys"

  echo "$registry"
}

# _playbook_print_cron_block <registry-json>
#   Prints the CEO Agent crontab block that would be installed for <registry>
#   to stdout, without touching the user's crontab. Skips collision detection
#   (dry-run only — collisions are caught by _playbook_update_crontab on the
#   real install path).
_playbook_print_cron_block() {
  local registry="$1"
  local marker_start="# CEO Agent START"
  local marker_end="# CEO Agent END"
  echo "$marker_start"
  while IFS= read -r row; do
    local p_name p_trigger p_schedule p_status
    p_name=$(echo "$row" | jq -r '.name')
    p_trigger=$(echo "$row" | jq -r '.trigger')
    p_schedule=$(echo "$row" | jq -r '.schedule')
    p_status=$(echo "$row" | jq -r '.status')
    if [ "$p_trigger" = "cron" ] && [ "$p_status" = "active" ] && [ -n "$p_schedule" ]; then
      echo "$p_schedule $CEO_CRON $p_name  # ceo:$p_name"
    fi
  done < <(echo "$registry" | jq -c '.playbooks[]')
  echo "$marker_end"
}

_playbook_update_crontab() {
  local registry="$1"
  local marker_start="# CEO Agent START"
  local marker_end="# CEO Agent END"

  # Collision detection — refuse to install duplicate schedules.
  # Two playbooks at the same minute fight for the global lock; one always
  # loses silently. Better to fail loud at scan time than skip-with-reason
  # at run time.
  local collisions
  collisions=$(echo "$registry" | jq -r '
    [.playbooks[] | select(.trigger == "cron" and .status == "active" and .schedule != "")]
    | group_by(.schedule)
    | map(select(length > 1))
    | .[] | "  \(.[0].schedule)  →  \([.[].name] | join(", "))"
  ')

  if [ -n "$collisions" ]; then
    echo "ERROR: schedule collision(s) detected — refusing to install crontab" >&2
    echo "$collisions" >&2
    echo "" >&2
    echo "Resolve via 'ceo schedule <playbook>' or by editing \$CEO_DIR/schedules.json." >&2
    return 1
  fi

  # Share the emission body with _playbook_print_cron_block so dry-run and
  # real install can't drift on the active+cron+scheduled filter.
  local cron_block cron_count
  cron_block=$(_playbook_print_cron_block "$registry")
  cron_count=$(printf '%s\n' "$cron_block" | grep -c '# ceo:' || true)

  local existing
  existing=$(ceo_scheduler_list 2>/dev/null || true)

  local new_crontab
  new_crontab=$(echo "$existing" | sed "/$marker_start/,/$marker_end/d")
  new_crontab=$(echo "$new_crontab" | grep -v "ceo-cron\.sh" || true)
  new_crontab=$(echo "$new_crontab" | grep -v "^# CEO Agent$" || true)

  # Scheduler can fail for non-collision reasons (locked spool, quota, RO fs,
  # missing crontab binary, unimplemented backend on Mac). The scheduler
  # abstraction emits its own ERROR line to stderr; we propagate the rc.
  local crontab_payload
  if [ -n "$new_crontab" ]; then
    crontab_payload=$(printf '%s\n%s\n' "$new_crontab" "$cron_block")
  else
    crontab_payload="$cron_block"
  fi

  local _install_rc=0
  ceo_scheduler_install "$crontab_payload" || _install_rc=$?
  if [ "$_install_rc" -ne 0 ]; then
    return "$_install_rc"
  fi

  echo "Crontab: $cron_count entries installed"
}

# Validate a 5-field cron expression. Lightweight syntax check — verifies
# field count and that each field uses only [0-9*,/-] characters. Rejects
# obvious typos; does not enforce range correctness (cron itself rejects
# out-of-range values when the line is installed).
#
# Uses `read -ra` instead of `for field in $expr` because the cron syntax
# includes literal `*` characters which would otherwise glob-expand against
# the current working directory (`*` → files in CWD), breaking validation
# in unpredictable ways.
_validate_cron_expr() {
  local expr="$1"
  if [ "$(echo "$expr" | awk '{print NF}')" != "5" ]; then
    echo "invalid: need 5 space-separated fields, got '$expr'"
    return 1
  fi
  local -a fields
  read -ra fields <<< "$expr"
  local i=0
  for field in "${fields[@]}"; do
    i=$((i + 1))
    case "$field" in
      *[!0-9*,/-]*)
        echo "invalid: field $i ('$field') contains unsupported characters"
        return 1 ;;
    esac
  done
  return 0
}

# Determine where the effective schedule for $1 came from.
# Echoes "override" if schedules.json has a value, "frontmatter" otherwise.
_schedule_source() {
  local name="$1"
  local overrides_file="$CEO_DIR/schedules.json"
  [ -f "$overrides_file" ] || { echo "frontmatter"; return; }
  jq -e --arg n "$name" '.[$n] // empty' "$overrides_file" >/dev/null 2>&1 \
    && echo "override" || echo "frontmatter"
}

cmd_schedule() {
  local registry_file="$CEO_DIR/registry.json"
  local overrides_file="$CEO_DIR/schedules.json"

  if [ ! -f "$registry_file" ]; then
    echo "ERROR: registry not found at $registry_file" >&2
    echo "Run: ceo playbook scan" >&2
    return 1
  fi

  local target="${1:-}"

  if [ -z "$target" ]; then
    _schedule_list "$registry_file"
    return 0
  fi

  _schedule_one "$target" "$registry_file" "$overrides_file"
}

_schedule_list() {
  local registry_file="$1"
  local registry
  registry=$(cat "$registry_file")

  printf "%-20s %-22s %-12s %s\n" "PLAYBOOK" "SCHEDULE" "SOURCE" "STATUS"
  printf "%-20s %-22s %-12s %s\n" "--------" "--------" "------" "------"

  local rows
  rows=$(echo "$registry" | jq -r '
    .playbooks[]
    | select(.trigger == "cron")
    | "\(.name)\t\(.schedule)\t\(.status)"
  ')

  # Compute collisions for this view.
  local collision_schedules
  collision_schedules=$(echo "$registry" | jq -r '
    [.playbooks[] | select(.trigger == "cron" and .status == "active" and .schedule != "")]
    | group_by(.schedule)
    | map(select(length > 1))
    | .[].[0].schedule
  ')

  while IFS=$'\t' read -r name sched status; do
    [ -z "$name" ] && continue
    local source flag
    source=$(_schedule_source "$name")
    flag=""
    if [ -n "$collision_schedules" ] && echo "$collision_schedules" | grep -qFx "$sched"; then
      flag=" ⚠ collides"
    fi
    printf "%-20s %-22s %-12s %s%s\n" "$name" "${sched:--}" "$source" "$status" "$flag"
  done <<< "$rows"
}

_schedule_one() {
  local name="$1"
  local registry_file="$2"
  local overrides_file="$3"

  local exists
  exists=$(jq -r --arg n "$name" '.playbooks[] | select(.name == $n) | .name' "$registry_file")
  if [ -z "$exists" ]; then
    echo "ERROR: no playbook named '$name' in registry" >&2
    echo "Run 'ceo schedule' (no args) to list active playbooks." >&2
    return 1
  fi

  local current trigger
  current=$(jq -r --arg n "$name" '.playbooks[] | select(.name == $n) | .schedule // ""' "$registry_file")
  trigger=$(jq -r --arg n "$name" '.playbooks[] | select(.name == $n) | .trigger' "$registry_file")

  if [ "$trigger" != "cron" ] && [ "$trigger" != "both" ]; then
    echo "ERROR: '$name' has trigger '$trigger' (need 'cron' or 'both')" >&2
    return 1
  fi

  echo "Current schedule for '$name': ${current:-<none>}"
  printf "New schedule (cron expr, e.g. '50 8 * * 1-5') or empty to cancel: "
  read -r new_schedule

  if [ -z "$new_schedule" ]; then
    echo "Cancelled."
    return 0
  fi

  local err
  err=$(_validate_cron_expr "$new_schedule")
  if [ $? -ne 0 ]; then
    echo "ERROR: $err" >&2
    return 1
  fi

  # Read or initialize overrides file.
  local overrides
  if [ -f "$overrides_file" ]; then
    overrides=$(cat "$overrides_file")
    if ! echo "$overrides" | jq empty 2>/dev/null; then
      echo "ERROR: $overrides_file is not valid JSON; refusing to write" >&2
      return 1
    fi
  else
    overrides='{}'
  fi

  # Apply the override.
  local updated
  updated=$(echo "$overrides" | jq --arg n "$name" --arg s "$new_schedule" '.[$n] = $s')

  local tmp="$overrides_file.tmp"
  echo "$updated" | jq '.' > "$tmp"
  mv "$tmp" "$overrides_file"

  echo "Wrote $overrides_file"
  echo "Re-running scan to apply…"
  echo ""
  cmd_playbook_scan
}

cmd_playbook_list() {
  local registry_file="$CEO_DIR/registry.json"
  _require_registry_current "$registry_file"

  printf "%-16s %-10s %-20s %-10s %-8s\n" "NAME" "TRIGGER" "SCHEDULE" "MODEL" "STATUS"
  printf "%-16s %-10s %-20s %-10s %-8s\n" "----" "-------" "--------" "-----" "------"

  while IFS= read -r row; do
    local p_name p_trigger p_schedule p_model p_status
    p_name=$(echo "$row" | jq -r '.name')
    p_trigger=$(echo "$row" | jq -r '.trigger')
    p_schedule=$(echo "$row" | jq -r '.schedule // "-"')
    p_model=$(echo "$row" | jq -r '.model // "-"')
    p_status=$(echo "$row" | jq -r '.status // "-"')
    [ "$p_schedule" = "" ] && p_schedule="-"
    [ "$p_model" = "" ] && p_model="-"
    printf "%-16s %-10s %-20s %-10s %-8s\n" "$p_name" "$p_trigger" "$p_schedule" "$p_model" "$p_status"
  done < <(jq -c '.playbooks[]' "$registry_file")
}

cmd_playbook_info() {
  local target="${1:-}"
  if [ -z "$target" ]; then
    echo "Usage: ceo playbook info <name>"
    exit 1
  fi

  local registry_file="$CEO_DIR/registry.json"
  _require_registry_current "$registry_file"

  local entry
  entry=$(jq -r --arg n "$target" '.playbooks[] | select(.name==$n)' "$registry_file")
  if [ -z "$entry" ]; then
    echo "Playbook not found: $target"
    echo "Available: $(jq -r '.playbooks[].name' "$registry_file" | tr '\n' ' ')"
    exit 1
  fi

  echo "=== Playbook: $target ==="
  echo ""
  echo "$entry" | jq -r 'to_entries[] | "  \(.key): \(.value)"'

  local last_run_file="$CEO_DIR/log/.last-run-$target"
  if [ -f "$last_run_file" ]; then
    echo ""
    echo "  last_run: $(cat "$last_run_file")"
  else
    echo ""
    echo "  last_run: never"
  fi

  local playbook_file
  playbook_file=$(echo "$entry" | jq -r '.file')
  local full_path
  if [[ "$playbook_file" = /* ]]; then
    full_path="$playbook_file"
  else
    full_path="$CEO_DIR/$playbook_file"
  fi
  if [ -f "$full_path" ]; then
    echo ""
    echo "--- Body ---"
    sed '1{/^---$/!q;};1,/^---$/d' "$full_path"
  fi
}

cmd_creds() {
  local subcmd="${1:-help}"
  shift 2>/dev/null || true
  local creds_file="$HOME/.config/ceo/credentials.env"

  case "$subcmd" in
    path)
      echo "$creds_file"
      ;;
    list)
      if [ ! -f "$creds_file" ]; then
        echo "Credentials file not found: $creds_file"
        exit 0
      fi
      echo "=== CEO Credentials ($creds_file) ==="
      grep -E '^[A-Za-z0-9_]+=' "$creds_file" | cut -d= -f1 || echo "No credentials found."
      ;;
    check)
      local playbook="${1:-}"
      if [ -z "$playbook" ]; then
        echo "Usage: ceo creds check <playbook>"
        exit 1
      fi
      ceo_require_vault
      local registry_file="$CEO_VAULT/CEO/registry.json"
      _require_registry_current "$registry_file"
      local entry
      entry=$(jq -r --arg n "$playbook" '.playbooks[] | select(.name==$n)' "$registry_file")
      if [ -z "$entry" ]; then
        echo "Playbook not found: $playbook"
        exit 1
      fi
      local requires
      requires=$(echo "$entry" | jq -r '.requires[]?' 2>/dev/null)
      if [ -z "$requires" ]; then
        echo "Playbook '$playbook' has no required credentials."
        exit 0
      fi
      
      if [ -f "$creds_file" ]; then
        # shellcheck source=/dev/null
        source "$creds_file"
      fi
      
      local missing=0
      while IFS= read -r req; do
        [ -z "$req" ] && continue
        if [ -z "${!req:-}" ]; then
          echo "✗ Missing: $req"
          missing=$((missing+1))
        else
          echo "✓ Found: $req"
        fi
      done <<< "$requires"
      
      if [ "$missing" -gt 0 ]; then
        echo ""
        echo "Playbook '$playbook' is missing $missing required credential(s)."
        exit 1
      else
        echo ""
        echo "All required credentials present for '$playbook'."
      fi
      ;;
    help|--help|-h)
      echo "Usage: ceo creds <list|check|path>"
      echo ""
      echo "  list               Show credential keys (never values)"
      echo "  check <playbook>   Check if required credentials for a playbook are present"
      echo "  path               Print the path to the credentials file"
      ;;
    *)
      echo "Unknown creds command: $subcmd"
      echo "Run: ceo creds help"
      exit 1
      ;;
  esac
}

cmd_setup() {
  if [ "${1:-}" = "discord" ]; then
    bash "$SCRIPT_DIR/ceo-setup-discord.sh"
    return
  fi
  local _os
  _os="$(ceo_detect_os)"
  case "$_os" in
    wsl)     bash "$SCRIPT_DIR/setup-wsl.sh" "$@" ;;
    macos)   bash "$SCRIPT_DIR/setup-mac.sh" "$@" ;;
    linux)   bash "$SCRIPT_DIR/setup-linux.sh" "$@" ;;
    unknown|*)
      echo "ceo setup: unsupported or undetected platform ('$_os')." >&2
      echo "  Supported: wsl, macos, linux." >&2
      echo "  Re-run on a supported host, or hand-write ~/.ceo/config (see docs)." >&2
      exit 1
      ;;
  esac
}

cmd_pr_sources() {
  echo "=== CEO PR Sources Configuration ==="
  echo ""
  echo "Configures which GitHub/GitLab accounts the morning brief queries."
  echo "Writes $(ceo_pr_sources_path)."
  echo ""
  ceo_pr_sources_setup
}

cmd_cron() {
  if [ $# -eq 0 ]; then
    echo "Usage: ceo cron <trigger>"
    echo "Triggers: inbox, morning-brief, pr-triage, pending-drip, eod-summary, cleanup"
    exit 1
  fi
  ceo_validate_vault || exit 1
  # Interactive invocation — bypass cooldown. Real cron calls ceo-cron.sh directly.
  CEO_FORCE=1 CEO_VERBOSE=1 "$CEO_CRON" "$1"
}

cmd_chat() {
  local name="${1:-triage}"
  ceo_validate_vault || exit 1
  local registry_file="$CEO_DIR/registry.json"

  _require_registry_current "$registry_file"

  local model="sonnet"
  local effort="${CEO_CHAT_EFFORT:-medium}"
  local playbook_content=""

  case "$effort" in
    low|medium|high|xhigh|max) ;;
    *)
      echo "Invalid CEO_CHAT_EFFORT='$effort' (expected: low, medium, high, xhigh, max)"
      exit 1
      ;;
  esac

  if [ "$name" = "triage" ]; then
    # No playbook — general triage conversation
    playbook_content="You are in triage mode. Read today's report and the vault state. Present what needs attention and work through priorities with Nathan."
  else
    local entry
    entry=$(jq -r --arg n "$name" '.playbooks[] | select(.name == $n)' "$registry_file" 2>/dev/null)
    if [ -z "$entry" ]; then
      echo "Playbook '$name' not found in registry."
      echo "Run 'ceo playbook list' to see available playbooks."
      echo "Or run 'ceo chat' with no args for general triage."
      exit 1
    fi

    local playbook_rel
    playbook_rel=$(echo "$entry" | jq -r '.file')
    model=$(echo "$entry" | jq -r '.model // "sonnet"')
    local playbook_file
    if [[ "$playbook_rel" = /* ]]; then
      playbook_file="$playbook_rel"
    else
      playbook_file="$CEO_DIR/$playbook_rel"
    fi

    if [ ! -f "$playbook_file" ]; then
      echo "Playbook file not found: $playbook_file"
      exit 1
    fi
    playbook_content=$(head -c 10000 "$playbook_file" 2>/dev/null || echo "")
  fi

  # Gather context
  source "$SCRIPT_DIR/ceo-gather.sh"
  if [ "$name" = "morning-scan" ] && [ -f "$SCRIPT_DIR/ceo-scan.sh" ]; then
    source "$SCRIPT_DIR/ceo-scan.sh"
  fi

  # Build system prompt from vault context + playbook
  local agents_content identity_content training_content
  agents_content=$(head -c 10000 "$CEO_DIR/AGENTS.md" 2>/dev/null || echo "")
  identity_content=$(head -c 10000 "$CEO_DIR/IDENTITY.md" 2>/dev/null || echo "")
  training_content=$(head -c 10000 "$CEO_DIR/TRAINING.md" 2>/dev/null || echo "")

  # Today's report for context
  local today_report=""
  local report_file
  report_file="$CEO_DIR/reports/$(date +%Y-%m-%d).md"
  [ -f "$report_file" ] && today_report=$(head -c 10000 "$report_file")

  local sys_prompt="You are the CEO agent in interactive mode. You are having a conversation with Nathan.

GLOBAL AGENT RULES:
$agents_content

CEO IDENTITY:
$identity_content

TRAINING:
$training_content

PLAYBOOK ($name):
$playbook_content

PRE-GATHERED DATA:
- Pending approvals: $PENDING_COUNT pending, $APPROVED_COUNT approved
- PRs for review: $PR_REVIEW_COUNT | PRs authored: $PR_AUTHORED_COUNT
- PR data (review requested): $PR_REVIEW_REQUESTED
- PR data (authored): $PR_AUTHORED

TODAY'S REPORT SO FAR:
${today_report:-No report yet today.}

You are in INTERACTIVE mode. Have a conversation. Ask questions. Wait for responses. Work through items collaboratively. Do not auto-execute high-stakes actions — propose them and wait for approval."

  # Add scan data if available
  if [ -n "${VAULT_CHANGES_BY_DOMAIN:-}" ]; then
    sys_prompt="$sys_prompt

VAULT SCAN DATA:
- Changes since last scan: $VAULT_CHANGES_COUNT files
- By domain:
$(printf '%b' "$VAULT_CHANGES_BY_DOMAIN")
- Yesterday's daily note:
$YESTERDAY_DAILY_NOTE
- Today's daily note:
$TODAY_DAILY_NOTE
- Pending questions:
$PENDING_QUESTIONS
- Pending approvals (unchecked):
$PENDING_APPROVALS_UNCHECKED
- Yesterday's report:
$YESTERDAY_REPORT"
  fi

  echo "Starting CEO chat ($name, model: $model, effort: $effort)..."
  echo ""

  cd "$VAULT" && claude --model "$model" --effort "$effort" --system-prompt "$sys_prompt"
}

cmd_trace() {
  local name="${1:-}"
  if [ -z "$name" ]; then
    echo "Usage: ceo trace <playbook-name> [--limit N]"
    echo ""
    echo "Returns claude-mem observations tagged with metadata.playbook_id == <playbook-name>,"
    echo "plus linked commits captured during the run."
    exit 1
  fi
  if [[ ! "$name" =~ ^[A-Za-z0-9_][A-Za-z0-9._-]*$ ]]; then
    echo "ERROR: invalid playbook name '$name' (must start with [A-Za-z0-9_]; allowed thereafter: A-Z a-z 0-9 . _ -)" >&2
    exit 1
  fi
  shift
  local limit=50
  while [ $# -gt 0 ]; do
    case "$1" in
      --limit)
        if [ -z "${2:-}" ] || [[ ! "$2" =~ ^[1-9][0-9]*$ ]]; then
          echo "ERROR: --limit must be a positive integer" >&2
          exit 1
        fi
        limit="$2"; shift 2 ;;
      --limit=*)
        limit="${1#--limit=}"
        if [[ ! "$limit" =~ ^[1-9][0-9]*$ ]]; then
          echo "ERROR: --limit must be a positive integer" >&2
          exit 1
        fi
        shift ;;
      *) echo "Unknown arg: $1" >&2; exit 1 ;;
    esac
  done

  ceo_validate_vault || exit 1
  local registry_file="$CEO_DIR/registry.json"
  if [ -f "$registry_file" ]; then
    if ! jq empty "$registry_file" 2>/dev/null; then
      echo "ERROR: $registry_file is not valid JSON. Run 'ceo playbook scan' to regenerate." >&2
      exit 1
    fi
    if ! jq -e --arg n "$name" '.playbooks[] | select(.name == $n)' "$registry_file" >/dev/null 2>&1; then
      echo "Warning: '$name' is not in $registry_file — searching anyway." >&2
    fi
  fi

  if ! command -v claude >/dev/null 2>&1; then
    echo "ERROR: 'claude' CLI not found. ceo trace uses claude --print to invoke MCP tools." >&2
    exit 1
  fi

  local prompt
  prompt="You are the CEO trace helper. Use the claude-mem MCP tools to find every observation tagged with playbook_id='$name', then summarize.

Steps:
1. Call mcp__claude-mem__observation_search with query='$name' and limit=$limit. If that tool is unavailable, fall back to mcp__claude-mem__memory_search.
2. For each result, call mcp__claude-mem__get_observations with the id and check metadata.playbook_id == '$name'. Discard non-matching ids.
3. Output a markdown table with columns: id | created_at | content (first 120 chars) | linked_commit (from metadata if present).
4. End with a one-line count: 'Total observations tagged $name: N'.

Do not call any tool other than the three above. Do not write to the filesystem."

  (
    cd "$VAULT" || exit 1
    unset CEO_PLAYBOOK_ID
    printf '%s' "$prompt" | claude --print --max-turns 8 --model sonnet \
      --allowed-tools "mcp__claude-mem__observation_search mcp__claude-mem__memory_search mcp__claude-mem__get_observations" \
      --disallowed-tools "Bash Write Edit"
  )
}

# Bind vault globals after ceo_require_vault has set CEO_VAULT.
_bind_vault() { VAULT="$CEO_VAULT"; CEO_DIR="$VAULT/CEO"; }

# Dispatch
# Sourcing guard: when CEO_LIB_ONLY=1, skip the dispatch table so test
# harnesses can pull in helper functions without firing a command.
if [ "${CEO_LIB_ONLY:-0}" = "1" ]; then
  return 0 2>/dev/null || exit 0
fi

case "${1:-help}" in
  setup)    shift; cmd_setup "$@" ;;
  pr-sources) cmd_pr_sources ;;
  next)     cmd_next ;;
  doctor)   cmd_doctor ;;
  preflight) ceo_require_vault; _bind_vault; cmd_preflight ;;
  test)     ceo_require_vault; _bind_vault; cmd_test ;;
  chat)     ceo_require_vault; _bind_vault; shift; cmd_chat "$@" ;;
  cron)     ceo_require_vault; _bind_vault; shift; cmd_cron "$@" ;;
  playbook) ceo_require_vault; _bind_vault; shift; cmd_playbook "$@" ;;
  trace)    ceo_require_vault; _bind_vault; shift; cmd_trace "$@" ;;
  schedule) ceo_require_vault; _bind_vault; shift; cmd_schedule "$@" ;;
  creds)    shift; cmd_creds "$@" ;;
  help|-h|--help) cmd_help ;;
  *)
    echo "Unknown command: $1"
    echo ""
    cmd_help
    exit 1
    ;;
esac
