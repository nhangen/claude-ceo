// Syncthing ignore for Obsidian vault — same file on Mac and WSL
// Copy to: ~/Documents/Obsidian/.stignore

// Obsidian internals
.obsidian
.trash

// OS files
.DS_Store
Thumbs.db
desktop.ini

// Editor temp files
*.swp
*.swo
*~

// Syncthing metadata (don't sync its own state)
.stfolder
.stversions

// Git repos inside vault (if any)
.git

// Node/build artifacts (if any tools run inside vault)
node_modules

// CEO runtime files that are machine-local (not vault state)
CEO/log/.last-run-*
CEO/log/.retry-*.json
CEO/log/.config-hash
CEO/log/.fail-count
// --dry-run preview output is host-local scratch (see ceo-cron.sh --dry-run)
CEO/log/preview/
// registry.json is host-local — it now lives at ~/.ceo/registry.json (each host
// regenerates its own via `ceo playbook scan`). Two hosts scanning a synced copy
// would both rewrite it and produce .sync-conflict files. Ignore any stale copy
// lingering in the vault from before the swarm migration; nothing should sync it.
// (CEO/swarm.json and CEO/heartbeats/ DO sync — they describe the swarm, not one host.)
CEO/registry.json
